+internal fun resolveSalesServerTicketValidationTimeoutMs(playCount: Int): Long {
+    val safePlayCount = playCount.coerceAtLeast(0)
+    if (safePlayCount <= 12) return SALES_SERVER_TICKET_VALIDATION_TIMEOUT_MS
+    val adaptive = SALES_SERVER_TICKET_VALIDATION_TIMEOUT_MS + ((safePlayCount - 12) * 110L)
+    return adaptive.coerceAtMost(SALES_SERVER_LARGE_TICKET_VALIDATION_TIMEOUT_MS)
+}
 
