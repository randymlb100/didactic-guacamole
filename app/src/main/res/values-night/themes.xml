<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LotteryNetPro" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#6366F1</item>
        <item name="colorPrimaryDark">#4F46E5</item>
        <item name="colorAccent">#10B981</item>
        <item name="android:windowBackground">#F8FAFC</item>
        <item name="android:statusBarColor">#6366F1</item>
        <item name="android:navigationBarColor">#123A63</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <style name="Theme.LotteryNetPro.Startup" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#312E81</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#F59E0B</item>
        <item name="windowSplashScreenAnimationDuration">180</item>
        <item name="postSplashScreenTheme">@style/Theme.LotteryNetPro</item>
    </style>
</resources>
